; FunAI Robot Map — Godot 4.6 專案設定
; 透明、無邊框、永遠置頂的桌面疊層；像素風用最近鄰取樣

config_version=5

[application]

config/name="FunAI Robot Map"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6")

[accessibility]

; AccessKit 在非內嵌子視窗(detail Window)聚焦時會炸 "Parameter wd is null"
; 桌面疊層不需要螢幕報讀 → 直接停用（0=自動 1=永遠 2=停用）
general/accessibility_support=2

[display]

window/size/viewport_width=640
window/size/viewport_height=400
window/size/transparent=true
window/size/borderless=true
window/size/always_on_top=false
window/per_pixel_transparency/allowed=true
window/subwindows/embed_subwindows=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
